datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  passwordHash String
  accounts     Account[]
  categories   Category[]
  transactions Transaction[]
  budgets      Budget[]
  credits      Credit[]
  createdAt    DateTime      @default(now())
}

model Account {
  id           String        @id @default(uuid())
  userId       String
  name         String
  type         String
  balance      Float         @default(0)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  createdAt    DateTime      @default(now())
}

model Category {
  id           String        @id @default(uuid())
  userId       String
  name         String
  type         String
  color        String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]
  createdAt    DateTime      @default(now())
}

model Transaction {
  id         String    @id @default(uuid())
  userId     String
  accountId  String
  categoryId String?
  amount     Float
  type       String    // "income", "expense", "transfer"
  date       String    // YYYY-MM-DD
  note       String?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  account    Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
}

model Budget {
  id          String   @id @default(uuid())
  userId      String
  categoryId  String
  limitAmount Float
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Credit {
  id           String        @id @default(uuid())
  userId       String
  name         String
  amount       Float
  interestRate Float
  rateType     String
  term         Int
  termType     String
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  installments Installment[]
}

model Installment {
  id                String  @id @default(uuid())
  creditId          String
  installmentNumber Int
  initialBalance    Float
  interest          Float
  amortization      Float
  totalInstallment  Float
  finalBalance      Float
  status            String  // "pending" or "paid"
  amountPaid        Float?  @default(0)
  credit            Credit  @relation(fields: [creditId], references: [id], onDelete: Cascade)
}
